{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiplane.dev/schemas/runtime-bundle/v1",
  "title": "aiplane runtime bundle",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "record_type",
    "render_only",
    "runtime",
    "model",
    "mode",
    "requested_mode",
    "files",
    "settings",
    "commands",
    "selected_file",
    "checksums",
    "supported_modes",
    "notes",
    "reproducibility"
  ],
  "properties": {
    "$schema": {
      "const": "schemas/aiplane-runtime-bundle-v1.schema.json"
    },
    "schema_version": {
      "const": "1.0"
    },
    "record_type": {
      "const": "runtime_bundle"
    },
    "render_only": {
      "const": true
    },
    "runtime": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "docker",
        "conda",
        "native"
      ]
    },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "minProperties": 1,
      "maxProperties": 1
    },
    "settings": {
      "type": "object"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_mode": {
      "enum": [
        "auto",
        "docker",
        "conda",
        "native"
      ]
    },
    "supported_modes": {
      "type": "array",
      "items": {
        "enum": [
          "docker",
          "conda",
          "native"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "selected_file": {
      "type": "string",
      "minLength": 1
    },
    "checksums": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "minProperties": 1,
      "maxProperties": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*:[A-Za-z0-9_.-]+$"
    },
    "reproducibility": {
      "type": "object",
      "required": [
        "level",
        "version_pinned",
        "digest_locked",
        "blockers"
      ],
      "properties": {
        "level": {
          "enum": [
            "recipe_deterministic",
            "version_pinned",
            "digest_locked"
          ]
        },
        "version_pinned": {
          "type": "boolean"
        },
        "digest_locked": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "docker"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "selected_file": {
            "const": "Dockerfile"
          },
          "files": {
            "required": [
              "Dockerfile"
            ]
          },
          "checksums": {
            "required": [
              "Dockerfile"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "conda"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "selected_file": {
            "const": "environment.yaml"
          },
          "files": {
            "required": [
              "environment.yaml"
            ]
          },
          "checksums": {
            "required": [
              "environment.yaml"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "native"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "selected_file": {
            "const": "runtime-launch.json"
          },
          "files": {
            "required": [
              "runtime-launch.json"
            ]
          },
          "checksums": {
            "required": [
              "runtime-launch.json"
            ]
          }
        }
      }
    }
  ]
}
