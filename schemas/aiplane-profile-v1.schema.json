{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiplane.dev/schemas/profile/v1",
  "title": "Aiplane canonical profile v1",
  "description": "Canonical combined representation rendered from an Aiplane multi-file profile directory.",
  "type": "object",
  "required": ["$schema", "schema_version", "name", "hardware", "backends", "repository", "tools", "approvals", "environment", "models", "targets", "orchestrators"],
  "additionalProperties": false,
  "$defs": {
    "modelAlias": {
      "type": "object",
      "required": ["model", "provider"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "enabled": {"type": "boolean"},
        "local": {"type": "boolean"},
        "min_ram_gb": {"type": "number", "minimum": 0},
        "recommended_ram_gb": {"type": "number", "minimum": 0},
        "min_vram_gb": {"type": "number", "minimum": 0},
        "recommended_vram_gb": {"type": "number", "minimum": 0},
        "parameters_b": {"type": "number", "minimum": 0},
        "roles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "supported_runtimes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "required_accelerator_apis": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "$schema": {"const": "https://aiplane.dev/schemas/profile/v1"},
    "schema_version": {"const": "1.0"},
    "name": {"type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$"},
    "hardware": {"type": "object"},
    "backends": {"type": "object"},
    "repository": {"type": "object"},
    "tools": {"type": "object"},
    "approvals": {"type": "object"},
    "environment": {
      "type": "object",
      "required": ["active", "modes"],
      "properties": {
        "active": {"type": "string", "minLength": 1},
        "modes": {"type": "object"}
      },
      "additionalProperties": true
    },
    "models": {
      "type": "object",
      "required": ["defaults", "models"],
      "properties": {
        "defaults": {"type": "object", "additionalProperties": {"type": ["string", "null"]}},
        "models": {"type": "object", "additionalProperties": {"$ref": "#/$defs/modelAlias"}},
        "providers": {"type": "object", "additionalProperties": {"type": "object"}}
      },
      "additionalProperties": true
    },
    "targets": {
      "type": "object",
      "required": ["default", "targets"],
      "properties": {
        "default": {"type": ["string", "null"]},
        "targets": {"type": "object", "additionalProperties": {"type": "object"}}
      },
      "additionalProperties": true
    },
    "orchestrators": {"type": "object"}
  }
}
